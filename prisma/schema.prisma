// ─────────────────────────────────────────────────────────────────────────────
// Harmonia Admin · Prisma schema  (the platform's single source of truth DB)
//
// harmonia-admin OWNS this database. The customer-facing client app has no DB —
// it consumes the admin's /api/public/* endpoints over HTTP.
//
// Multi-tenancy: SHARED DATABASE + SHARED SCHEMA with a `tenantId` discriminator
// on every business entity (row-level isolation). `Tenant` is the platform root
// aggregate; `slug` is the brandable/routable identifier. The service layer is
// the single chokepoint that injects/enforces the active tenant scope.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum UserRole {
  SUPER_ADMIN // Harmonia staff — cross-tenant, manages tenants & their data
  TENANT_ADMIN // manages only their own tenant
  TENANT_STAFF // scoped operational access within a tenant
}

enum CustomerStatus {
  ACTIVE
  BLOCKED
}

enum ServiceType {
  EXPERIENCE // date · people · options · extras (per-person)
  TRANSFER // date/time · vehicle (per-trip)
  PRODUCT // quantity only (fixed price)
  QUOTE // enquiry, no fixed price ("sur devis")
}

enum PriceMode {
  PER_PERSON
  PER_TRIP
  FIXED
  ON_QUOTE
}

enum MediaType {
  IMAGE
  VIDEO
}

enum ReservationStatus {
  PENDING // booking request submitted, awaiting admin confirmation
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentProvider {
  MANUAL
  STRIPE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum CouponType {
  PERCENT
  FIXED
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  REJECTED
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
}

enum ContactStatus {
  NEW
  READ
  ARCHIVED
}

enum TokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

// ─── Tenancy & platform ──────────────────────────────────────────────────────

/// Root aggregate. Owned by the platform, not by a tenant.
model Tenant {
  id     String       @id @default(cuid())
  slug   String       @unique // routing / branding / future custom domain
  name   String
  status TenantStatus @default(ACTIVE)

  // Profile (self-service surface)
  description  String?
  contactEmail String?
  contactPhone String?
  logoUrl      String?
  coverUrl     String?

  // Branding & locale (white-label ready)
  themeJson       Json?
  defaultCurrency String @default("MAD")
  defaultLocale   String @default("fr")
  timezone        String @default("Africa/Casablanca")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Tenant-owned data
  domains         TenantDomain[]
  users           User[]
  customers       Customer[]
  categories      Category[]
  services        Service[]
  carts           Cart[]
  reservations    Reservation[]
  payments        Payment[]
  coupons         Coupon[]
  reviews         Review[]
  vendors         Vendor[]
  properties      Property[]
  contactMessages ContactMessage[]
  notifications   Notification[]
  auditLogs       AuditLog[]

  @@index([status])
  @@map("tenants")
}

/// Future custom domains / subdomains for a tenant (not used yet).
model TenantDomain {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  host       String    @unique
  isPrimary  Boolean   @default(false)
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId])
  @@map("tenant_domains")
}

// ─── Identity & auth ─────────────────────────────────────────────────────────

/// Back-office principals (Harmonia super admins + tenant admins/staff).
model User {
  id           String    @id @default(cuid())
  tenantId     String? // null = SUPER_ADMIN (operates across all tenants)
  tenant       Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String    @unique
  name         String?
  phone        String?
  city         String?
  role         UserRole  @default(TENANT_STAFF)
  passwordHash String
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  refreshTokens RefreshToken[]

  @@index([tenantId])
  @@map("users")
}

/// Customer-facing end users of the client website.
model Customer {
  id              String         @id @default(cuid())
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email           String
  name            String?
  phone           String?
  city            String?
  preferredLocale String? // default language for this customer (e.g. "fr")
  passwordHash    String?
  emailVerifiedAt DateTime?
  status          CustomerStatus @default(ACTIVE)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  carts         Cart[]
  reservations  Reservation[]
  reviews       Review[]
  refreshTokens RefreshToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("customers")
}

/// Rotating refresh tokens (hashed) for custom JWT auth — supports logout/revoke.
model RefreshToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  userAgent  String?
  ip         String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([customerId])
  @@map("refresh_tokens")
}

/// Email verification / password reset tokens (hashed).
model VerificationToken {
  id         String    @id @default(cuid())
  identifier String // email
  tokenHash  String    @unique
  type       TokenType
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([identifier])
  @@map("verification_tokens")
}

// ─── Catalog ─────────────────────────────────────────────────────────────────

model Category {
  id          String  @id @default(cuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // 2-level tree: a category may have one parent (no deeper nesting in UI).
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryTree")
  slug        String
  name        String
  description String?
  imageUrl    String?
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services Service[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([parentId])
  @@map("categories")
}

/// Tenant-owned catalog item. Every operation is filtered by `tenantId`.
model Service {
  id              String  @id @default(cuid())
  tenantId        String
  tenant          Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])
  slug            String
  type            ServiceType @default(EXPERIENCE)

  // Pricing & booking parameters (drive the customer booking form)
  priceCents      Int       @default(0)
  currency        String    @default("MAD") // base/price currency
  acceptedCurrencies String[] @default([]) // currencies accepted for payment
  priceMode       PriceMode @default(PER_PERSON)
  requiresDate    Boolean   @default(true)
  minPeople       Int?
  maxPeople       Int?
  durationMinutes Int?
  capacity        Int?
  languages       String[]  @default([])

  // Media
  coverUrl     String?
  thumbUrl     String?

  // ALL human text lives here — peer locales, no canonical column. Keyed by
  // locale, e.g. { "fr": { title, subtitle, description, priceUnit, tags[],
  // options[], extras[], included[], info[] }, "en": { … } }. At least one
  // locale carries a title; reads fall back across locales.
  translations Json?

  active          Boolean @default(true)
  featured        Boolean @default(false)
  ratingCached    Float   @default(0) // denormalised for fast catalog reads
  reviewCountCached Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  media            ServiceMedia[]
  options          ServiceOption[]
  extras           ServiceExtra[]
  slots            AvailabilitySlot[]
  cartItems        CartItem[]
  reservationItems ReservationItem[]
  reviews          Review[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@map("services")
}

model ServiceMedia {
  id        String    @id @default(cuid())
  serviceId String
  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  url       String
  type      MediaType @default(IMAGE)
  alt       String?
  sortOrder Int       @default(0)

  @@index([serviceId])
  @@map("service_media")
}

/// Variant/formula of a service (price delta vs. base).
model ServiceOption {
  id              String  @id @default(cuid())
  serviceId       String
  service         Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name            String
  priceDeltaCents Int     @default(0)
  isDefault       Boolean @default(false)
  sortOrder       Int     @default(0)

  cartItems        CartItem[]
  reservationItems ReservationItem[]

  @@index([serviceId])
  @@map("service_options")
}

/// Optional add-on for a service.
model ServiceExtra {
  id         String  @id @default(cuid())
  serviceId  String
  service    Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name       String
  priceCents Int     @default(0)
  sortOrder  Int     @default(0)

  @@index([serviceId])
  @@map("service_extras")
}

/// Bookable time slot for a service.
model AvailabilitySlot {
  id          String   @id @default(cuid())
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  startsAt    DateTime
  endsAt      DateTime
  capacity    Int      @default(1)
  bookedCount Int      @default(0)

  @@index([serviceId, startsAt])
  @@map("availability_slots")
}

// ─── Commerce / bookings ─────────────────────────────────────────────────────

model Cart {
  id         String     @id @default(cuid())
  tenantId   String
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  sessionId  String? // anonymous/guest cart key
  status     CartStatus @default(ACTIVE)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  items CartItem[]

  @@index([tenantId])
  @@index([sessionId])
  @@map("carts")
}

model CartItem {
  id             String         @id @default(cuid())
  cartId         String
  cart           Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  serviceId      String
  service        Service        @relation(fields: [serviceId], references: [id])
  optionId       String?
  option         ServiceOption? @relation(fields: [optionId], references: [id])
  quantity       Int            @default(1)
  scheduledAt    DateTime?
  extrasJson     Json? // snapshot of chosen extras
  unitPriceCents Int

  @@index([cartId])
  @@map("cart_items")
}

/// A booking request. Customer submits → admin confirms.
model Reservation {
  id            String            @id @default(cuid())
  tenantId      String
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId    String
  customer      Customer          @relation(fields: [customerId], references: [id])
  code          String            @unique // human-friendly reference
  locale        String            @default("fr") // language the booking was made in (drives docs/emails)
  status        ReservationStatus @default(PENDING)
  subtotalCents Int               @default(0)
  discountCents Int               @default(0)
  totalCents    Int               @default(0)
  currency      String            @default("MAD")
  scheduledAt   DateTime?
  notes         String?
  couponId      String?
  coupon        Coupon?           @relation(fields: [couponId], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  items    ReservationItem[]
  payments Payment[]
  review   Review?

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([customerId])
  @@map("reservations")
}

model ReservationItem {
  id             String         @id @default(cuid())
  reservationId  String
  reservation    Reservation    @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  serviceId      String
  service        Service        @relation(fields: [serviceId], references: [id])
  optionId       String?
  option         ServiceOption? @relation(fields: [optionId], references: [id])
  title          String // snapshot of service title at booking time
  quantity       Int            @default(1)
  unitPriceCents Int
  scheduledAt    DateTime?
  extrasJson     Json?

  @@index([reservationId])
  @@map("reservation_items")
}

model Payment {
  id            String          @id @default(cuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservationId String
  reservation   Reservation     @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  provider      PaymentProvider @default(MANUAL)
  providerRef   String?
  amountCents   Int
  currency      String          @default("MAD")
  status        PaymentStatus   @default(PENDING)
  method        String?
  paidAt        DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([tenantId])
  @@index([reservationId])
  @@map("payments")
}

model Coupon {
  id         String     @id @default(cuid())
  tenantId   String
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code       String
  type       CouponType @default(PERCENT)
  value      Int // percent (0-100) or fixed minor units
  validFrom  DateTime?
  validTo    DateTime?
  usageLimit Int?
  usedCount  Int        @default(0)
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  reservations Reservation[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("coupons")
}

model Review {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  customerId    String
  customer      Customer     @relation(fields: [customerId], references: [id])
  reservationId String?      @unique
  reservation   Reservation? @relation(fields: [reservationId], references: [id])
  rating        Int // 1..5
  title         String?
  body          String?
  status        ReviewStatus @default(PENDING)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([tenantId])
  @@index([serviceId, status])
  @@map("reviews")
}

// ─── Operations ──────────────────────────────────────────────────────────────

model Vendor {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  contactEmail String?
  phone        String?
  notes        String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@map("vendors")
}

model Property {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  addressLine String?
  city        String?
  type        String?
  status      PropertyStatus @default(ACTIVE)
  ownerName   String?
  ownerEmail  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([tenantId])
  @@map("properties")
}

model ContactMessage {
  id        String        @id @default(cuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  status    ContactStatus @default(NEW)
  createdAt DateTime      @default(now())

  @@index([tenantId])
  @@map("contact_messages")
}

model Notification {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recipientType String // "USER" | "CUSTOMER"
  recipientId   String?
  type          String
  title         String?
  payloadJson   Json?
  readAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([tenantId])
  @@index([recipientType, recipientId])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorId   String?
  actorType String? // "USER" | "CUSTOMER" | "SYSTEM"
  action    String
  entity    String
  entityId  String?
  dataJson  Json?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([entity, entityId])
  @@map("audit_logs")
}
