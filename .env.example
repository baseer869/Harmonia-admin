# ─── Harmonia Admin · environment ───
# Copy to `.env` for local dev. In prod (Railway/Vercel/Render) set these as
# the service's environment variables — never commit real secrets.

# PostgreSQL connection string used by Prisma (lib/db).
# On Railway use the Postgres plugin value: ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/harmonia_admin?schema=public"

# Secret that signs admin + customer JWT session cookies.
# Generate with: openssl rand -base64 48
AUTH_SECRET="replace-me-with-a-long-random-string"

# Public origin of the CLIENT website. Drives CORS on /api/public/* and the
# cross-site customer cookie. In prod set the deployed client URL, e.g.
# https://harmonia-client.up.railway.app
CLIENT_ORIGIN="http://localhost:3000"

# Public app metadata
NEXT_PUBLIC_APP_NAME="Harmonia Admin"
NEXT_PUBLIC_APP_URL="http://localhost:3100"
